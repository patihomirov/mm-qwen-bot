# Пример переменных окружения для mm-qwen-bot
# Скопируйте в .env и заполните значениями

MM_URL=http://your-mattermost:8065
MM_BOT_TOKEN=your-bot-token
MM_OWNER_USERNAME=your-username

# Speech-to-Text (опционально)
GROQ_API_KEY=your-groq-api-key
STT_LANGUAGE=ru

# AI Backend
AI_BACKEND=qwen
QWEN_PATH=~/.npm-global/bin/qwen
# CLAUDE_PATH=~/.npm-global/bin/claude
